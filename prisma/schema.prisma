// =========================================================
// 1. CONFIGURAÇÕES E ENUMS
// =========================================================

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

enum UserType {
  CLIENT
  PROFESSIONAL
  ADMIN
}

enum AdminRole {
  OWNER
  FINANCE
  SUPPORT
}

// Diferencia os "mundos" dentro da plataforma
enum Industry {
  TECH // Desenvolvedores, Designers, Freelancers (Padrão atual)
  HEALTH // Psicólogos, Nutricionistas, Personal Trainers
}

enum ProjectStatus {
  OPEN // Aberto para receber propostas
  WAITING_PAYMENT // Cliente aceitou proposta, aguardando pagamento (Escrow)
  IN_PROGRESS // Pago e em desenvolvimento
  UNDER_REVIEW // Profissional entregou, cliente está revisando
  COMPLETED // Finalizado e dinheiro liberado
  CANCELED // Cancelado antes de começar
  DISPUTE // Deu problema (Mediação)
}

enum ProposalStatus {
  PENDING
  ACCEPTED
  REJECTED
  WITHDRAWN
}

// [NOVO] Status das consultas na área da saúde (Enterprise Level) - Renomeado para Bypass
enum BookingStatus {
  PENDING_PAYMENT // Aguardando pagamento no Stripe
  PAID // Pago, aguardando confirmação final do profissional (se houver)
  CONFIRMED // Confirmado e na agenda
  COMPLETED // Realizada
  CANCELED // Cancelada
  DISPUTED // Em disputa pelo paciente
  REFUNDED // Reembolsado ao paciente
  NO_SHOW // Paciente não compareceu
}

// =========================================================
// 2. MODELO DE USUÁRIO (Principal)
// =========================================================

enum TransactionType {
  CREDIT
  DEBIT
}

enum TransactionStatus {
  PENDING
  PROCESSING
  COMPLETED
  FAILED
  CANCELED
  DISPUTED
}

enum WithdrawalStatus {
  PENDING
  PROCESSING
  COMPLETED
  FAILED
  CANCELED
}

enum ProjectCheckoutHoldStatus {
  PENDING
  COMPLETED
  EXPIRED
  CANCELED
  FAILED
}

enum ChargebackLiabilityStatus {
  OPEN
  PARTIALLY_RECOVERED
  RECOVERED
  WAIVED
}

enum NotificationType {
  MESSAGE
  SUCCESS
  WARNING
  INFO
}

enum HealthSpecialty {
  PSYCHOLOGIST
  NUTRITIONIST
  PERSONAL_TRAINER
  LAWYER
  ENGLISH_TEACHER
}

model User {
  id            String     @id @default(uuid())
  name          String
  displayName   String?
  email         String     @unique
  emailVerified DateTime?
  image         String?
  password      String?
  birthDate     DateTime?
  userType      UserType   @default(CLIENT)
  isActive      Boolean    @default(true)
  adminRole     AdminRole?

  // Campo que define de qual "setor" o utilizador é
  industry Industry @default(TECH)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  profileViews Int @default(0)

  // --- Dados de Perfil Gerais ---
  bio         String?  @db.Text
  city        String?
  state       String?
  hourlyRate  Decimal?
  rating      Float    @default(0)
  ratingCount Int      @default(0)

  // =========================================================
  // CAMPOS DE ENDEREÇO E CONTATO
  // =========================================================
  phone         String?
  gender        String? // Ex: "M" ou "F"
  cep           String?
  address       String? // Logradouro / Rua
  addressNumber String? // Número
  complement    String? // Complemento
  neighborhood  String? // Bairro

  // =========================================================
  // [CAMPOS PROFISSIONAIS - SETOR TECH]
  // =========================================================
  jobTitle          String?
  yearsOfExperience Int?
  skills            String[] @default([])
  socialGithub      String?
  socialLinkedin    String?
  portfolio         Json?    @default("[]")
  certificates      Json?    @default("[]")

  // =========================================================
  // [CAMPOS PROFISSIONAIS - SETOR HEALTH]
  // =========================================================
  documentReg     String? // Para CRM, CRP, CREF, etc. (Ex: "CRP 06/12345")
  approach        String? // Abordagem clínica (Ex: "TCC", "Psicanálise")
  consultationFee Decimal? // Valor fixo da consulta base
  sessionDuration Int?     @default(50) // Duração da sessão em minutos (Padrão 50min)

  // Armazenamento de Imagem no Banco
  profileImageBytes Bytes?
  profileImageType  String?

  // --- RECUPERAÇÃO DE SENHA ---
  resetCode       String?
  resetCodeExpiry DateTime?

  // =========================================================
  // [INTEGRAÇÃO STRIPE - ASSINATURA]
  // =========================================================
  stripeCustomerId         String?   @unique
  stripeSubscriptionId     String?   @unique
  stripePriceId            String?
  stripeCurrentPeriodEnd   DateTime?
  stripeSubscriptionStatus String?

  // =========================================================
  // [DADOS FINANCEIROS - RECEBIMENTO DE TRABALHO]
  // =========================================================
  pendingBalance Decimal @default(0)
  walletBalance  Decimal @default(0)
  chargebackDebt Decimal @default(0)
  pixKey         String?
  pixKeyType     String?

  transactions                 Transaction[]
  paymentTermsAcceptances      PaymentTermsAcceptance[]
  professionalTermsAcceptances ProfessionalTermsAcceptance[]
  withdrawalRequests           WithdrawalRequest[]
  clientRecordsAsPro           ClientRecord[]                @relation("ProfessionalRecords")
  clientRecordsAsPat           ClientRecord[]                @relation("PatientRecords")
  sessionNotesWritten          SessionNote[]                 @relation("ProfessionalSessionNotes")
  legalCasesWritten            LegalCase[]                   @relation("ProfessionalLegalCases")
  legalActivitiesWritten       LegalCaseActivity[]           @relation("ProfessionalLegalActivities")

  // --- Relacionamentos Tech ---
  projectsOwned    Project[]     @relation("ClientProjects")
  projectsAssigned Project[]     @relation("ProProjects")
  proposals        Proposal[]    @relation("ProfessionalProposals")
  deliverables     Deliverable[] @relation("UserDeliverables")

  // --- Relacionamentos Health (Atualizados) ---
  patientAppointments Appointment[]              @relation("PatientAppointments")
  proAppointments     Appointment[]              @relation("ProAppointments")
  services            ServiceType[]              @relation("ProServices")
  availabilities      ProfessionalAvailability[] @relation("ProAvailability")
  exceptions          AvailabilityException[]    @relation("ProExceptions")

  // --- Relacionamentos Gerais ---
  conversationsAsA Conversation[]  @relation("ParticipantA")
  conversationsAsB Conversation[]  @relation("ParticipantB")
  sentMessages     Message[]       @relation("SentMessages")
  favorites        Favorite[]      @relation("UserFavorites")
  favoritedBy      Favorite[]      @relation("FavoritedBy")
  reviewsWritten   Review[]        @relation("ReviewsAuthored")
  reviewsReceived  Review[]        @relation("ReviewsReceived")
  accounts         Account[]
  sessions         Session[]
  adminAuditLogs   AdminAuditLog[] @relation("AdminAuditActor")
  notifications    Notification[]  @relation("UserNotifications")

  @@index([isActive])
}

// =========================================================
// 3. MODELOS DE NEGÓCIO - TECH (PROJETOS)
// =========================================================

model Project {
  id          String   @id @default(uuid())
  title       String
  description String   @db.Text
  category    String
  tags        String[]

  budgetType  String
  budgetValue Decimal
  budgetLabel String

  agreedPrice Decimal?

  deadline String

  status ProjectStatus @default(OPEN)

  stripeSessionId       String?   @unique
  stripePaymentIntentId String?
  canceledAt            DateTime?
  cancellationReason    String?   @db.Text
  revisionRequestedAt   DateTime?
  revisionReason        String?   @db.Text
  disputeReason         String?   @db.Text
  disputeOpenedAt       DateTime?
  disputeResolvedAt     DateTime?
  disputeResolution     String?   @db.Text

  attachments Json? @default("[]")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  ownerId String
  owner   User   @relation("ClientProjects", fields: [ownerId], references: [id])

  professionalId String?
  professional   User?   @relation("ProProjects", fields: [professionalId], references: [id])

  bidsCount Int @default(0)

  proposals    Proposal[]
  deliverables Deliverable[]
  reviews      Review[]

  @@index([status])
  @@index([stripePaymentIntentId])
}

model Proposal {
  id             String         @id @default(uuid())
  price          Decimal
  estimatedDays  Int
  coverLetter    String         @db.Text
  status         ProposalStatus @default(PENDING)
  projectId      String
  project        Project        @relation(fields: [projectId], references: [id], onDelete: Cascade)
  professionalId String
  professional   User           @relation("ProfessionalProposals", fields: [professionalId], references: [id])
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt

  @@index([projectId])
  @@index([professionalId])
}

model Deliverable {
  id          String   @id @default(uuid())
  description String?
  fileUrl     String?
  link        String?
  projectId   String
  project     Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  senderId    String
  sender      User     @relation("UserDeliverables", fields: [senderId], references: [id])
  createdAt   DateTime @default(now())
}

model ProjectCheckoutHold {
  id                    String                    @id @default(cuid())
  projectId             String
  proposalId            String
  buyerId               String
  stripeSessionId       String?                   @unique
  stripePaymentIntentId String?
  checkoutUrl           String?                   @db.Text
  amount                Decimal
  currency              String                    @default("brl")
  status                ProjectCheckoutHoldStatus @default(PENDING)
  expiresAt             DateTime
  completedAt           DateTime?
  canceledAt            DateTime?
  failedAt              DateTime?
  failureReason         String?                   @db.Text
  createdAt             DateTime                  @default(now())
  updatedAt             DateTime                  @updatedAt

  @@index([projectId])
  @@index([proposalId])
  @@index([buyerId])
  @@index([status])
  @@index([stripeSessionId])
}

// =========================================================
// [NOVO] 4. MODELOS DE NEGÓCIO - HEALTH (CONSULTAS AVANÇADAS)
// =========================================================

model ServiceType {
  id             String        @id @default(uuid())
  professionalId String
  professional   User          @relation("ProServices", fields: [professionalId], references: [id], onDelete: Cascade)
  name           String // Ex: "Sessão Terapia", "Primeira Consulta"
  duration       Int // Duração em minutos
  price          Decimal
  isActive       Boolean       @default(true)
  appointments   Appointment[]
}

model ProfessionalAvailability {
  id             String  @id @default(uuid())
  professionalId String
  professional   User    @relation("ProAvailability", fields: [professionalId], references: [id], onDelete: Cascade)
  dayOfWeek      Int // 0 = Domingo, 1 = Segunda, etc.
  startTime      String // Ex: "08:00"
  endTime        String // Ex: "18:00"
  isActive       Boolean @default(true)

  @@unique([professionalId, dayOfWeek])
}

model AvailabilityException {
  id             String   @id @default(uuid())
  professionalId String
  professional   User     @relation("ProExceptions", fields: [professionalId], references: [id], onDelete: Cascade)
  date           DateTime @db.Date // Dia do feriado/folga
  isAvailable    Boolean  @default(false) // false = bloqueado o dia todo
  startTime      String? // Opcional: inicio de atendimento parcial
  endTime        String? // Opcional: fim de atendimento parcial
  reason         String? // Ex: "Feriado", "Férias"
}

model AppointmentHold {
  id              String   @id @default(uuid())
  professionalId  String
  patientId       String
  date            DateTime @db.Date
  time            String
  expiresAt       DateTime // UTC para expiração do carrinho (Ex: now + 15 min)
  stripeSessionId String?  @unique
  createdAt       DateTime @default(now())

  // Índice para leitura rápida na hora de checar slots ocupados
  @@unique([professionalId, date, time])
}

model Appointment {
  id             String        @id @default(uuid())
  shortId        String        @unique @default(uuid()) // Código público com fallback para não dar erro
  date           DateTime      @db.Date
  time           String
  timezonePro    String        @default("America/Sao_Paulo")
  timezoneClient String        @default("America/Sao_Paulo")
  status         BookingStatus @default(PENDING_PAYMENT)

  meetLink        String?
  price           Decimal
  notes           String?   @db.Text
  stripeSessionId String?   @unique
  disputeReason   String?   @db.Text
  disputeOpenedAt DateTime?

  // Rastreamento de aceite dos termos de pagamento
  acceptedPaymentTerms   Boolean   @default(false)
  paymentTermsAcceptedAt DateTime?
  paymentTermsIpAddress  String? // IP de onde foi aceito (para compliance)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  patientId String
  patient   User   @relation("PatientAppointments", fields: [patientId], references: [id])

  professionalId String
  professional   User   @relation("ProAppointments", fields: [professionalId], references: [id])

  serviceTypeId String?
  serviceType   ServiceType? @relation(fields: [serviceTypeId], references: [id])

  sessionNote  SessionNote?
  transactions Transaction[]

  // Ajuda a prevenir consultas duplicadas no mesmo horário
  @@index([patientId])
  @@index([professionalId])
}

model ClientRecord {
  id             String          @id @default(cuid())
  professionalId String
  patientId      String
  specialty      HealthSpecialty

  // Pre-filled from patient User data, kept for snapshot
  patientName   String
  patientEmail  String?
  patientPhone  String?
  patientBirth  DateTime?
  patientGender String?
  patientCity   String?

  // Common clinical fields
  chiefComplaint String? @db.Text
  generalNotes   String? @db.Text

  // Psychology-specific permanent fields
  // These are stored as dedicated columns for querying and reporting
  emergencyContactName  String?
  emergencyContactPhone String?
  emergencyContactRel   String?
  occupation            String?
  previousTreatments    String?  @db.Text
  familyHistory         String?  @db.Text
  continuousMedications String?  @db.Text
  sessionValueAgreed    Decimal?
  sessionFrequency      String?
  fixedSessionDay       String?
  fixedSessionTime      String?

  // Nutrition-specific permanent fields
  nutritionDiagnosedPathologies String?  @db.Text
  nutritionFamilyHistory        String?  @db.Text
  nutritionMedications          String?  @db.Text
  intestinalFunction            String?
  sleepQuality                  String?
  stressLevel                   String?
  physicalActivity              String?  @db.Text
  waterIntakeLiters             Decimal?
  alcoholConsumption            String?
  smokingStatus                 String?
  foodAllergies                 String?  @db.Text
  foodAversions                 String?  @db.Text
  foodPreferences               String?  @db.Text
  foodPattern                   String?

  // English teacher-specific permanent fields
  englishCurrentLevel        String?
  englishMainGoal            String?
  englishPreviousExperience  String?  @db.Text
  englishInitialDifficulties String?  @db.Text
  englishClassMode           String?
  englishClassFrequency      String?
  englishClassDuration       String?
  englishBillingAmount       Decimal?

  // Lawyer-specific permanent fields
  legalPersonType         String?
  legalNationality        String?
  legalCpf                String?
  legalRg                 String?
  legalMaritalStatus      String?
  legalCompanyName        String?
  legalTradeName          String?
  legalCnpj               String?
  legalStateRegistration  String?
  legalRepresentativeName String?
  legalRepresentativeCpf  String?
  legalContactEmail       String?
  legalContactPhones      String?
  legalAddress            String? @db.Text

  // Specialty-specific fields stored as flexible JSON
  specialtyData Json? @default("{}")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  professional User          @relation("ProfessionalRecords", fields: [professionalId], references: [id])
  patient      User          @relation("PatientRecords", fields: [patientId], references: [id])
  sessionNotes SessionNote[]
  legalCases   LegalCase[]

  @@unique([professionalId, patientId])
  @@index([professionalId])
  @@index([patientId])
}

model LegalCase {
  id             String @id @default(cuid())
  clientRecordId String
  professionalId String

  title           String
  legalArea       String?
  processNumber   String?
  court           String?
  clientPosition  String?
  opposingParty   String?
  opposingCounsel String?
  factsSummary    String? @db.Text
  feeType         String?
  feeDetails      String? @db.Text
  status          String  @default("ACTIVE")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  clientRecord ClientRecord        @relation(fields: [clientRecordId], references: [id], onDelete: Cascade)
  professional User                @relation("ProfessionalLegalCases", fields: [professionalId], references: [id])
  activities   LegalCaseActivity[]

  @@index([clientRecordId])
  @@index([professionalId])
  @@index([processNumber])
}

model LegalCaseActivity {
  id             String @id @default(cuid())
  legalCaseId    String
  professionalId String

  activityDate     DateTime
  activityType     String
  timeSpentMinutes Int?
  description      String    @db.Text
  deadlineDate     DateTime?
  reminderDays     Int?
  filesNotes       String?   @db.Text

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  legalCase    LegalCase @relation(fields: [legalCaseId], references: [id], onDelete: Cascade)
  professional User      @relation("ProfessionalLegalActivities", fields: [professionalId], references: [id])

  @@index([legalCaseId])
  @@index([professionalId])
  @@index([deadlineDate])
}

model SessionNote {
  id             String  @id @default(cuid())
  clientRecordId String
  appointmentId  String? @unique
  professionalId String

  sessionDate  DateTime
  content      String   @db.Text
  evolution    String?  @db.Text
  nextSteps    String?  @db.Text
  privateNotes String?  @db.Text

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  clientRecord ClientRecord @relation(fields: [clientRecordId], references: [id], onDelete: Cascade)
  appointment  Appointment? @relation(fields: [appointmentId], references: [id])
  professional User         @relation("ProfessionalSessionNotes", fields: [professionalId], references: [id])

  @@index([clientRecordId])
  @@index([professionalId])
}

// =========================================================
// 5. INFRAESTRUTURA COMPARTILHADA (FINANCEIRO, CHAT E AUTH)
// =========================================================

model Transaction {
  id String @id @default(uuid())

  userId String
  user   User   @relation(fields: [userId], references: [id])

  amount      Decimal
  type        TransactionType
  status      TransactionStatus
  description String

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  projectId String?

  appointmentId String?
  appointment   Appointment? @relation(fields: [appointmentId], references: [id])

  @@index([projectId])
  @@index([appointmentId])
  @@index([userId, status])
}

model WithdrawalRequest {
  id            String           @id @default(cuid())
  userId        String
  transactionId String           @unique
  amount        Decimal
  pixKey        String
  pixKeyType    String
  status        WithdrawalStatus @default(PENDING)
  provider      String           @default("MANUAL_PIX")
  providerRef   String?
  createdAt     DateTime         @default(now())
  updatedAt     DateTime         @updatedAt

  user User @relation(fields: [userId], references: [id])

  @@index([userId])
  @@index([status])
}

model TechChargebackLiability {
  id                 String                    @id @default(cuid())
  projectId          String
  professionalId     String
  stripeDisputeId    String                    @unique
  stripePaymentId    String?
  grossAmount        Decimal
  professionalAmount Decimal
  recoveredAmount    Decimal                   @default(0)
  outstandingAmount  Decimal                   @default(0)
  status             ChargebackLiabilityStatus @default(OPEN)
  reason             String?                   @db.Text
  createdAt          DateTime                  @default(now())
  updatedAt          DateTime                  @updatedAt

  @@index([projectId])
  @@index([professionalId])
  @@index([status])
}

model AdminAuditLog {
  id               String   @id @default(uuid())
  actorId          String
  actor            User     @relation("AdminAuditActor", fields: [actorId], references: [id])
  action           String
  entityType       String
  entityId         String
  reason           String?  @db.Text
  receiptUrl       String?  @db.Text
  receiptFileBytes Bytes?
  receiptFileType  String?
  receiptFileName  String?
  metadata         Json?    @default("{}")
  createdAt        DateTime @default(now())

  @@index([actorId])
  @@index([entityType, entityId])
  @@index([action])
  @@index([createdAt])
}

model Review {
  id        String   @id @default(uuid())
  rating    Int
  comment   String?  @db.Text
  projectId String
  project   Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  authorId  String
  author    User     @relation("ReviewsAuthored", fields: [authorId], references: [id])
  targetId  String
  target    User     @relation("ReviewsReceived", fields: [targetId], references: [id])
  createdAt DateTime @default(now())

  @@unique([projectId, authorId])
  @@index([targetId])
  @@index([projectId])
}

model Conversation {
  id              String    @id @default(uuid())
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  lastMessageTime DateTime  @default(now())
  lastMessage     String?
  participantAId  String
  participantA    User      @relation("ParticipantA", fields: [participantAId], references: [id])
  participantBId  String
  participantB    User      @relation("ParticipantB", fields: [participantBId], references: [id])
  unreadCountA    Int       @default(0)
  unreadCountB    Int       @default(0)
  deletedByIds    String[]  @default([])
  messages        Message[]

  @@unique([participantAId, participantBId])
}

model Message {
  id             String       @id @default(uuid())
  content        String       @db.Text
  read           Boolean      @default(false)
  createdAt      DateTime     @default(now())
  senderId       String
  sender         User         @relation("SentMessages", fields: [senderId], references: [id])
  conversationId String
  conversation   Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
}

model Notification {
  id         String           @id @default(cuid())
  userId     String
  user       User             @relation("UserNotifications", fields: [userId], references: [id], onDelete: Cascade)
  actorId    String?
  type       NotificationType @default(INFO)
  eventType  String
  title      String
  message    String           @db.Text
  link       String?
  entityType String
  entityId   String
  metadata   Json?            @default("{}")
  readAt     DateTime?
  createdAt  DateTime         @default(now())
  updatedAt  DateTime         @updatedAt

  @@unique([userId, entityType, entityId, eventType])
  @@index([userId, readAt, createdAt])
  @@index([entityType, entityId])
}

model Favorite {
  id             String   @id @default(uuid())
  createdAt      DateTime @default(now())
  clientId       String
  client         User     @relation("UserFavorites", fields: [clientId], references: [id], onDelete: Cascade)
  professionalId String
  professional   User     @relation("FavoritedBy", fields: [professionalId], references: [id], onDelete: Cascade)

  @@unique([clientId, professionalId])
}

model Account {
  id                String  @id @default(uuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(uuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model RateLimit {
  key       String   @id
  count     Int      @default(0)
  resetAt   DateTime
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([resetAt])
}

model PaymentTermsAcceptance {
  id              String   @id @default(cuid())
  userId          String
  stripeSessionId String?
  acceptedAt      DateTime @default(now())
  ipAddress       String
  termsVersion    String   @default("v1.0")
  userAgent       String?

  user User @relation(fields: [userId], references: [id])

  @@index([userId])
  @@index([stripeSessionId])
}

model StripeEventLog {
  id                  String            @id @default(cuid())
  stripeEventId       String            @unique
  type                String
  status              StripeEventStatus @default(RECEIVED)
  attempts            Int               @default(0)
  lastError           String?           @db.Text
  processingStartedAt DateTime?
  processedAt         DateTime?
  failedAt            DateTime?
  createdAt           DateTime          @default(now())
  updatedAt           DateTime          @updatedAt

  @@index([stripeEventId])
  @@index([status])
}

model ProfessionalTermsAcceptance {
  id           String   @id @default(cuid())
  userId       String
  acceptedAt   DateTime @default(now())
  ipAddress    String
  termsVersion String   @default("professional-v1.0")
  userAgent    String?

  user User @relation(fields: [userId], references: [id])

  @@index([userId])
}

enum StripeEventStatus {
  RECEIVED
  PROCESSING
  PROCESSED
  FAILED
}
