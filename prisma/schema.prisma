// =========================================================
// 1. CONFIGURAÇÕES E ENUMS
// =========================================================

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

enum UserType {
  CLIENT
  PROFESSIONAL
  ADMIN
}

// [NOVO] Enum para Status do Projeto (Fluxo Financeiro)
enum ProjectStatus {
  OPEN             // Aberto para receber propostas
  WAITING_PAYMENT  // Cliente aceitou proposta, aguardando pagamento (Escrow)
  IN_PROGRESS      // Pago e em desenvolvimento
  UNDER_REVIEW     // Profissional entregou, cliente está revisando
  COMPLETED        // Finalizado e dinheiro liberado
  CANCELED         // Cancelado antes de começar
  DISPUTE          // Deu problema (Mediação)
}

// [NOVO] Enum para Status da Proposta
enum ProposalStatus {
  PENDING
  ACCEPTED
  REJECTED
  WITHDRAWN // Profissional desistiu da proposta
}

// =========================================================
// 2. MODELO DE USUÁRIO (Principal)
// =========================================================

model User {
  id            String    @id @default(uuid())
  name          String
  displayName   String?
  email         String    @unique
  password      String
  birthDate     DateTime?
  userType      UserType  @default(CLIENT)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  
  // --- Dados de Perfil ---
  bio            String?   @db.Text
  city           String?
  state          String?
  hourlyRate     Float?    
  rating         Float     @default(5.0) 
  jobTitle       String?   
  skills         String[]  @default([])
  socialGithub   String?
  socialLinkedin String?
  
  // --- JSONs ---
  portfolio      Json?     @default("[]") 
  certificates   Json?     @default("[]")

  // --- Relacionamentos de Projetos ---
  projectsOwned    Project[] @relation("ClientProjects")
  projectsAssigned Project[] @relation("ProProjects")

  // [NOVO] Relações para Propostas e Entregas
  proposals     Proposal[]    @relation("ProfessionalProposals") // Propostas que enviei
  deliverables  Deliverable[] @relation("UserDeliverables")      // Entregas que fiz

  // --- Relacionamentos de Chat ---
  conversationsAsA Conversation[] @relation("ParticipantA")
  conversationsAsB Conversation[] @relation("ParticipantB")
  
  sentMessages   Message[]        @relation("SentMessages")

  // --- Relacionamentos de Favoritos ---
  favorites      Favorite[] @relation("UserFavorites")
  favoritedBy    Favorite[] @relation("FavoritedBy")
}

// =========================================================
// 3. MODELO DE PROJETOS
// =========================================================

model Project {
  id          String   @id @default(uuid())
  title       String
  description String   @db.Text
  category    String   // Ex: "TI e Programação"
  tags        String[] // Array de tags ex: ["React", "Node"]
  
  // Orçamento Original (Estimativa do Cliente)
  budgetType  String   // "fixed" ou "hourly"
  budgetValue Float    // Valor numérico para filtros
  budgetLabel String   // Texto formatado ex: "R$ 1500,00"
  
  // [NOVO] Valor Final Acordado (Escrow)
  agreedPrice Decimal? // Valor que fechou na proposta aceita
  
  deadline    String   // "Urgente", "Para essa semana", etc.
  
  // [MODIFICADO] Usando o Enum ProjectStatus no lugar de String
  // Para compatibilidade, se der erro de migration, podemos mapear,
  // mas idealmente migramos para o Enum novo.
  status      ProjectStatus @default(OPEN) 
  
  // Anexos (Links)
  attachments Json?    @default("[]") 

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  ownerId       String
  owner         User      @relation("ClientProjects", fields: [ownerId], references: [id])
  
  professionalId String?
  professional   User?     @relation("ProProjects", fields: [professionalId], references: [id])
  
  bidsCount     Int       @default(0)

  // [NOVO] Relacionamentos para o Fluxo de Trabalho
  proposals     Proposal[]    // Lista de propostas recebidas
  deliverables  Deliverable[] // Arquivos entregues pelo profissional
}

// =========================================================
// 4. NOVO MODEL: PROPOSTA (Proposal)
// =========================================================

model Proposal {
  id            String   @id @default(uuid())
  
  price         Decimal  // Valor que o profissional cobrou
  estimatedDays Int      // Prazo em dias
  coverLetter   String   @db.Text // A mensagem de venda/apresentação
  
  status        ProposalStatus @default(PENDING)
  
  // Relacionamentos
  projectId     String
  project       Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  
  professionalId String
  professional   User    @relation("ProfessionalProposals", fields: [professionalId], references: [id])

  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([projectId])
  @@index([professionalId])
}

// =========================================================
// 5. NOVO MODEL: ENTREGA (Deliverable)
// =========================================================

model Deliverable {
  id            String   @id @default(uuid())
  
  description   String?  // Comentário sobre a entrega ("Segue anexo v1")
  fileUrl       String?  // URL do arquivo (AWS S3, Uploadthing, etc)
  link          String?  // Link externo (Github, Figma, Drive)
  
  // Relacionamentos
  projectId     String
  project       Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  
  senderId      String   // Quem enviou (geralmente o profissional)
  sender        User     @relation("UserDeliverables", fields: [senderId], references: [id])

  createdAt     DateTime @default(now())
}

// =========================================================
// 6. MODELOS DE CHAT (Conversas e Mensagens)
// =========================================================

model Conversation {
  id             String    @id @default(uuid())
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
  
  lastMessageTime DateTime  @default(now()) 
  lastMessage     String?   

  participantAId String
  participantA   User    @relation("ParticipantA", fields: [participantAId], references: [id])

  participantBId String
  participantB   User    @relation("ParticipantB", fields: [participantBId], references: [id])

  unreadCountA Int @default(0) 
  unreadCountB Int @default(0) 

  deletedByIds String[] @default([]) 

  messages       Message[]

  @@unique([participantAId, participantBId])
}

model Message {
  id             String       @id @default(uuid())
  content        String       @db.Text
  read           Boolean      @default(false)
  createdAt      DateTime     @default(now())
  
  senderId       String
  sender         User         @relation("SentMessages", fields: [senderId], references: [id])
  
  conversationId String
  conversation   Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
}

// =========================================================
// 7. MODELO DE FAVORITOS
// =========================================================

model Favorite {
  id             String   @id @default(uuid())
  createdAt      DateTime @default(now())

  clientId       String
  client         User     @relation("UserFavorites", fields: [clientId], references: [id], onDelete: Cascade)

  professionalId String
  professional   User     @relation("FavoritedBy", fields: [professionalId], references: [id], onDelete: Cascade)

  @@unique([clientId, professionalId])
}