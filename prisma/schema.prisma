// =========================================================
// 1. CONFIGURAÇÕES E ENUMS
// =========================================================

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

enum UserType {
  CLIENT
  PROFESSIONAL
  ADMIN
}

enum ProjectStatus {
  OPEN             // Aberto para receber propostas
  WAITING_PAYMENT  // Cliente aceitou proposta, aguardando pagamento (Escrow)
  IN_PROGRESS      // Pago e em desenvolvimento
  UNDER_REVIEW     // Profissional entregou, cliente está revisando
  COMPLETED        // Finalizado e dinheiro liberado
  CANCELED         // Cancelado antes de começar
  DISPUTE          // Deu problema (Mediação)
}

enum ProposalStatus {
  PENDING
  ACCEPTED
  REJECTED
  WITHDRAWN
}

// =========================================================
// 2. MODELO DE USUÁRIO (Principal)
// =========================================================

model User {
  id             String    @id @default(uuid())
  name           String
  displayName    String?
  email          String    @unique
  password       String
  birthDate      DateTime?
  userType       UserType  @default(CLIENT)
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
  
  // --- Dados de Perfil ---
  bio             String?   @db.Text
  city            String?
  state           String?
  hourlyRate      Float?    
  rating          Float     @default(5.0) 
  
  // Campos Profissionais
  jobTitle        String?            // Ex: Eletricista, Advogado
  yearsOfExperience Int?           // Tempo de experiência
  skills          String[]  @default([])
  
  socialGithub    String?
  socialLinkedin  String?
  
  // Armazenamento de Imagem no Banco (Postgres BYTEA)
  profileImageBytes Bytes?   // O arquivo binário da imagem
  profileImageType  String?  // O tipo do arquivo (ex: "image/jpeg")

  // --- NOVOS CAMPOS: RECUPERAÇÃO DE SENHA ---
  resetCode       String?   // Código de 6 dígitos para reset
  resetCodeExpiry DateTime? // Data de validade do código
  
  // --- JSONs ---
  portfolio       Json?     @default("[]") 
  certificates    Json?     @default("[]")

  // --- Relacionamentos de Projetos ---
  projectsOwned    Project[] @relation("ClientProjects")
  projectsAssigned Project[] @relation("ProProjects")

  // --- Relacionamentos de Propostas e Entregas ---
  proposals        Proposal[]    @relation("ProfessionalProposals")
  deliverables     Deliverable[] @relation("UserDeliverables")       

  // --- Relacionamentos de Chat ---
  conversationsAsA Conversation[] @relation("ParticipantA")
  conversationsAsB Conversation[] @relation("ParticipantB")
  
  sentMessages     Message[]         @relation("SentMessages")

  // --- Relacionamentos de Favoritos ---
  favorites       Favorite[] @relation("UserFavorites")
  favoritedBy     Favorite[] @relation("FavoritedBy")
}

// =========================================================
// 3. MODELO DE PROJETOS E OUTROS
// =========================================================

model Project {
  id           String    @id @default(uuid())
  title        String
  description  String    @db.Text
  category     String    
  tags         String[] 
  
  budgetType   String    
  budgetValue  Float      
  budgetLabel  String    
  
  agreedPrice  Decimal? 
  
  deadline     String    
  
  status       ProjectStatus @default(OPEN) 
  
  attachments  Json?     @default("[]") 

  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  ownerId         String
  owner           User      @relation("ClientProjects", fields: [ownerId], references: [id])
  
  professionalId  String?
  professional    User?     @relation("ProProjects", fields: [professionalId], references: [id])
  
  bidsCount       Int       @default(0)

  proposals       Proposal[]    
  deliverables    Deliverable[] 
}

model Proposal {
  id             String    @id @default(uuid())
  price          Decimal  
  estimatedDays  Int      
  coverLetter    String    @db.Text 
  status         ProposalStatus @default(PENDING)
  projectId      String
  project        Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  professionalId String
  professional   User    @relation("ProfessionalProposals", fields: [professionalId], references: [id])
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@index([projectId])
  @@index([professionalId])
}

model Deliverable {
  id             String    @id @default(uuid())
  description    String?  
  fileUrl        String?  
  link           String?  
  projectId      String
  project        Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  senderId       String    
  sender         User      @relation("UserDeliverables", fields: [senderId], references: [id])
  createdAt      DateTime @default(now())
}

model Conversation {
  id               String    @id @default(uuid())
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt
  lastMessageTime  DateTime  @default(now()) 
  lastMessage      String?    
  participantAId   String
  participantA     User    @relation("ParticipantA", fields: [participantAId], references: [id])
  participantBId   String
  participantB     User    @relation("ParticipantB", fields: [participantBId], references: [id])
  unreadCountA     Int     @default(0) 
  unreadCountB     Int     @default(0) 
  deletedByIds     String[] @default([]) 
  messages         Message[]
  @@unique([participantAId, participantBId])
}

model Message {
  id               String       @id @default(uuid())
  content          String       @db.Text
  read             Boolean      @default(false)
  createdAt        DateTime     @default(now())
  senderId         String
  sender           User         @relation("SentMessages", fields: [senderId], references: [id])
  conversationId   String
  conversation     Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
}

model Favorite {
  id               String   @id @default(uuid())
  createdAt        DateTime @default(now())
  clientId         String
  client           User     @relation("UserFavorites", fields: [clientId], references: [id], onDelete: Cascade)
  professionalId   String
  professional     User     @relation("FavoritedBy", fields: [professionalId], references: [id], onDelete: Cascade)
  @@unique([clientId, professionalId])
}