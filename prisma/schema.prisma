datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

enum UserType {
  CLIENT
  PROFESSIONAL
  ADMIN
}

model User {
  id          String   @id @default(uuid())
  name        String
  displayName String?
  email       String   @unique
  password    String
  birthDate   DateTime?

  userType    UserType @default(CLIENT)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}
