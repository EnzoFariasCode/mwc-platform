// =========================================================
// 1. CONFIGURAÇÕES E ENUMS
// =========================================================

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

enum UserType {
  CLIENT
  PROFESSIONAL
  ADMIN
}

// =========================================================
// 2. MODELO DE USUÁRIO (Principal)
// =========================================================

model User {
  id          String    @id @default(uuid())
  name        String
  displayName String?
  email       String    @unique
  password    String
  birthDate   DateTime?
  userType    UserType  @default(CLIENT)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  
  // --- Dados de Perfil ---
  bio            String?   @db.Text
  city           String?
  state          String?
  hourlyRate     Float?    
  rating         Float     @default(5.0) 
  jobTitle       String?   
  skills         String[]  @default([])
  socialGithub   String?
  socialLinkedin String?
  
  // --- JSONs ---
  portfolio      Json?     @default("[]") 
  certificates   Json?     @default("[]")

  // --- Relacionamentos de Projetos ---
  projectsOwned    Project[] @relation("ClientProjects")
  projectsAssigned Project[] @relation("ProProjects")

  // --- Relacionamentos de Chat ---
  // Conversas das quais o usuário participa
  // [MODIFICADO]: Agora usamos relation explícita para saber quem é quem
  conversationsAsA Conversation[] @relation("ParticipantA")
  conversationsAsB Conversation[] @relation("ParticipantB")
  
  // Mensagens enviadas pelo usuário
  sentMessages  Message[]       @relation("SentMessages")

  // --- Relacionamentos de Favoritos ---
  // Quem esse usuário favoritou (Ex: Cliente favoritou Eletricista)
  favorites      Favorite[] @relation("UserFavorites")
  // Quem favoritou este usuário (Ex: Eletricista foi favoritado por X clientes)
  favoritedBy    Favorite[] @relation("FavoritedBy")
}

// =========================================================
// 3. MODELO DE PROJETOS
// =========================================================

model Project {
  id          String   @id @default(uuid())
  title       String
  description String   @db.Text
  category    String   // Ex: "TI e Programação"
  tags        String[] // Array de tags ex: ["React", "Node"]
  
  // Orçamento
  budgetType  String   // "fixed" ou "hourly"
  budgetValue Float    // Valor numérico para filtros
  budgetLabel String   // Texto formatado ex: "R$ 1500,00" ou "R$ 50/h"
  
  deadline    String   // "Urgente", "Para essa semana", etc.
  status      String   @default("OPEN") // OPEN, IN_PROGRESS, COMPLETED
  
  // Anexos (Links)
  attachments Json?    @default("[]") 

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  ownerId      String
  owner        User     @relation("ClientProjects", fields: [ownerId], references: [id])
  
  professionalId String?
  professional   User?    @relation("ProProjects", fields: [professionalId], references: [id])
  
  bidsCount    Int      @default(0)
}

// =========================================================
// 4. MODELOS DE CHAT (Conversas e Mensagens)
// =========================================================

// Agrupa mensagens entre dois ou mais usuários
model Conversation {
  id            String    @id @default(uuid())
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  
  // Campo auxiliar para ordenação (data da última mensagem)
  // [MODIFICADO]: Renomeei de lastMessageAt para lastMessageTime para bater com seu código frontend
  lastMessageTime DateTime  @default(now()) 
  lastMessage     String?   // [NOVO] Snippet da última mensagem para exibir na lista sem join

  // [NOVO] Participantes explícitos (Melhor para query de chat 1x1)
  participantAId String
  participantA   User   @relation("ParticipantA", fields: [participantAId], references: [id])

  participantBId String
  participantB   User   @relation("ParticipantB", fields: [participantBId], references: [id])

  // [NOVO] Contadores de mensagens não lidas para cada participante
  unreadCountA Int @default(0) // Quantas msgs o Participante A não leu
  unreadCountB Int @default(0) // Quantas msgs o Participante B não leu

  // [NOVO] Soft Delete: Quem apagou essa conversa da sua lista?
  deletedByIds String[] @default([]) // Array de IDs

  // Mensagens dentro desta conversa
  messages      Message[]

  // Garante que só existe UMA conversa única entre A e B
  @@unique([participantAId, participantBId])
  // Índice para busca rápida de conversas deletadas
}

model Message {
  id             String       @id @default(uuid())
  content        String       @db.Text
  read           Boolean      @default(false)
  createdAt      DateTime     @default(now())
  
  // Quem enviou
  senderId       String
  sender         User         @relation("SentMessages", fields: [senderId], references: [id])
  
  // A qual conversa pertence
  conversationId String
  conversation   Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
}

// =========================================================
// 5. MODELO DE FAVORITOS
// =========================================================

model Favorite {
  id             String   @id @default(uuid())
  createdAt      DateTime @default(now())

  // O Cliente que clicou no coração
  clientId       String
  client         User     @relation("UserFavorites", fields: [clientId], references: [id], onDelete: Cascade)

  // O Profissional que foi favoritado
  professionalId String
  professional   User     @relation("FavoritedBy", fields: [professionalId], references: [id], onDelete: Cascade)

  // Garante que o cliente só possa favoritar o mesmo profissional uma vez
  @@unique([clientId, professionalId])
}